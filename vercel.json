{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "out",
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "bash scripts/vercel/prepare.sh",
  "buildCommand": "bash scripts/vercel/build.sh",
  "redirects": [
    {
      "source": "/branding",
      "destination": "/about/branding",
      "permanent": true
    },
    {
      "source": "/docs/api/:path((?!v\\d+\\.x).*)",
      "destination": "/docs/api/v5.x/:path",
      "permanent": false
    }
  ]
}
